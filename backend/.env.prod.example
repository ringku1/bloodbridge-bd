# .env.prod.example
#
# Copy to .env.prod on your EC2 instance:
#   cp .env.prod.example .env.prod
#
# Fill every value marked TODO before starting the container.
# NEVER commit .env.prod to git.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Comma-separated — your domain + admin dashboard domain
ALLOWED_ORIGINS=https://api.yourdomain.com,https://admin.yourdomain.com

# ─── Database (AWS RDS PostgreSQL) ───────────────────────────────────────────
# RDS Console → your instance → Connectivity → Endpoint
# Format: postgresql://user:password@<rds-endpoint>:5432/blooddonor
DATABASE_URL=postgresql://blooddonor_user:STRONG_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/blooddonor

# ─── Cache & Queue (AWS ElastiCache Redis) ────────────────────────────────────
# ElastiCache Console → your cluster → Primary Endpoint
# Format: redis://:<auth-token>@<elasticache-endpoint>:6379
REDIS_URL=redis://your-elasticache-endpoint.cache.amazonaws.com:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_generate_64_byte_hex_string
JWT_EXPIRES_IN=30d

# ─── Admin ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=TODO_generate_32_byte_hex_string

# ─── OTP / SMS (SSL Wireless) ─────────────────────────────────────────────────
USE_MOCK_SMS=false
SSL_WIRELESS_API_KEY=TODO
SSL_WIRELESS_SID=TODO
SSL_WIRELESS_SENDER=BloodBridge

# ─── Push Notifications (Expo Push) ──────────────────────────────────────────
# No credentials needed — Expo Push is credential-free on the backend.

# ─── Twilio Proxy (optional v1) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=

# ─── File Storage (AWS S3) ────────────────────────────────────────────────────
# IAM Console → your user → Security credentials → Create access key
AWS_ACCESS_KEY_ID=TODO
AWS_SECRET_ACCESS_KEY=TODO
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=blood-bridge-nid-photos
# No AWS_ENDPOINT or MINIO_PUBLIC_URL in production — SDK routes to real AWS automatically
