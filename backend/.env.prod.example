# .env.prod.example
#
# Production environment variables for the Vercel + Neon + Redis Cloud + Koyeb architecture.
#
# WHERE to set these:
#   Vercel API  → Vercel dashboard → your project → Settings → Environment Variables
#   Koyeb worker → Koyeb dashboard → your service → Environment
#
# Variables marked [API] are needed on Vercel only.
# Variables marked [WORKER] are needed on Koyeb only.
# Variables marked [BOTH] are needed on both.
#
# NEVER commit real values to git.

# ─── Server [API only] ────────────────────────────────────────────────────────
# Vercel sets NODE_ENV=production automatically — do not set it manually.
# ALLOWED_ORIGINS: leave blank for mobile-only apps (no browser Origin header).
ALLOWED_ORIGINS=

# ─── Database [BOTH] ──────────────────────────────────────────────────────────
# Neon → your project → Dashboard → Connection Details → Connection string (pooled)
# Use the POOLED connection string for Vercel serverless (pgbouncer=true&connection_limit=1)
# Use the DIRECT connection string for Koyeb worker (prisma migrate needs direct connection)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/blooddonor?sslmode=require

# ─── Redis [BOTH] ─────────────────────────────────────────────────────────────
# Redis Cloud → your database → Configuration → Public endpoint
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:your_password@redis-xxxxx.c1.ap-southeast-1-1.ec2.redns.redis-cloud.com:12345

# ─── JWT [BOTH] ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_64_byte_hex
JWT_EXPIRES_IN=30d

# ─── Admin [API only] ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 32+ characters.
ADMIN_SECRET=TODO_32_byte_hex

# ─── OTP / SMS [BOTH] ─────────────────────────────────────────────────────────
# Start with USE_MOCK_SMS=true until SSL Wireless account is ready.
# OTP will be printed to Vercel function logs instead of sending real SMS.
USE_MOCK_SMS=true
SSL_WIRELESS_API_KEY=TODO
SSL_WIRELESS_SID=TODO
SSL_WIRELESS_SENDER=BloodBridge

# ─── Push Notifications [BOTH] ────────────────────────────────────────────────
# Expo Push is credential-free — no variables needed.

# ─── Twilio Proxy [API only] — Optional, leave blank for v1 ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=

# ─── File Storage [API only] ──────────────────────────────────────────────────
# Option A: Cloudflare R2 (free 10 GB, no egress fees — recommended)
#   cloudflare.com → R2 → Create bucket → Manage R2 API tokens → Create token (Object Read & Write)
#
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
AWS_REGION=auto
AWS_S3_BUCKET=blood-bridge-nid-photos
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
#
# Option B: AWS S3 (requires credit card but has free 5 GB for 12 months)
#   IAM → Create user → AmazonS3FullAccess → Create access key
#
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=blood-bridge-nid-photos
# (no AWS_ENDPOINT — SDK routes to real AWS automatically)
