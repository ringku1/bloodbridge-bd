# .env.prod.example
#
# Production environment variables for the Vercel + Neon + Redis Cloud + Backblaze B2 stack.
#
# WHERE to set these:
#   Vercel API → Vercel dashboard → your project → Settings → Environment Variables
#
# NEVER commit real values to git.

# ─── Server ───────────────────────────────────────────────────────────────────
# Vercel sets NODE_ENV=production automatically — do not set it manually.
# ALLOWED_ORIGINS: leave blank for mobile-only apps (no browser Origin header).
ALLOWED_ORIGINS=

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon → your project → Dashboard → Connection Details → "Connection string (pooled)"
# Use the POOLED string for Vercel serverless (adds pgbouncer=true&connection_limit=1)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/blooddonor?sslmode=require&pgbouncer=true&connection_limit=1

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis Cloud → your database → Configuration → Public endpoint
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:your_password@redis-xxxxx.c1.ap-southeast-1-1.ec2.redns.redis-cloud.com:12345

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_64_byte_hex
JWT_EXPIRES_IN=30d

# ─── Admin ────────────────────────────────────────────────────────────────────
# Must be 32+ characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=TODO_32_byte_hex

# ─── Cron (Cloudflare Worker) ─────────────────────────────────────────────────
# Shared secret between the Cloudflare Worker and this API.
# Must match the CRON_SECRET variable set in the Cloudflare Worker environment.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=TODO_32_byte_hex

# ─── OTP / SMS ────────────────────────────────────────────────────────────────
# Start with USE_MOCK_SMS=true until SSL Wireless account is ready.
# OTP will print to Vercel function logs instead of sending real SMS.
USE_MOCK_SMS=true
SSL_WIRELESS_API_KEY=TODO
SSL_WIRELESS_SID=TODO
SSL_WIRELESS_SENDER=BloodBridge

# ─── Push Notifications ───────────────────────────────────────────────────────
# Expo Push is credential-free — no variables needed.

# ─── Twilio Proxy — Optional, leave blank for v1 ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=

# ─── File Storage (Backblaze B2 — recommended: free 10 GB, no credit card) ───
#   backblaze.com → B2 Cloud Storage → Buckets → Create bucket (Private)
#   App Keys → Add Application Key (Read & Write) → copy keyID + applicationKey
#   Endpoint shown on bucket page (e.g. https://s3.us-west-004.backblazeb2.com)
#
AWS_ACCESS_KEY_ID=your_backblaze_keyID
AWS_SECRET_ACCESS_KEY=your_backblaze_applicationKey
AWS_REGION=us-west-004
AWS_S3_BUCKET=blood-bridge-nid-photos
AWS_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#
# Alternative: Cloudflare R2 (free 10 GB, no egress fees — requires credit card on file)
#   cloudflare.com → R2 → Create bucket → Manage R2 API tokens → Create token
#
# AWS_ACCESS_KEY_ID=your_r2_access_key_id
# AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# AWS_REGION=auto
# AWS_S3_BUCKET=blood-bridge-nid-photos
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
