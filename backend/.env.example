# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# This .env.example file is safe to commit (no real values).
#
# For production: set these same variables in RunSite → Environment tab


# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Production: NODE_ENV=production
# Production: ALLOWED_ORIGINS=https://your-admin.vercel.app
ALLOWED_ORIGINS=


# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: "postgres" is the Docker service name.
# Production: copy internal URL from RunSite → PostgreSQL → Connect tab
DATABASE_URL=postgresql://user:password@postgres:5432/blooddonor


# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: "redis" is the Docker service name.
# Production: copy internal URL from RunSite → Redis → Connect tab
REDIS_URL=redis://redis:6379


# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d


# ─── Admin ────────────────────────────────────────────────────────────────────
# Must be 32+ characters in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_this_admin_secret_in_production


# ─── OTP / SMS (SSL Wireless — Bangladesh) ────────────────────────────────────
# USE_MOCK_SMS=true  → OTP printed to console. No SMS sent. Use in dev.
# USE_MOCK_SMS=false → Real SMS. Fill keys below. Get from sslwireless.com
USE_MOCK_SMS=true
SSL_WIRELESS_API_KEY=your_api_key_here
SSL_WIRELESS_SID=your_sid_here
SSL_WIRELESS_SENDER=BloodBridge


# ─── Push Notifications (Expo Push — no credentials needed) ──────────────────
# Expo Push is credential-free on the backend.
# Mobile app registers its token via PUT /api/donors/fcm-token.
# For production builds: cd mobile && npx eas init


# ─── Twilio Proxy (Masked Calls) — Optional for v1 ───────────────────────────
# Leave blank — mock mode returns fake proxy numbers automatically.
# Production (v2): twilio.com → Proxy → Services → Create a Service
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=


# ─── File Storage (NID Photos) ───────────────────────────────────────────────

# ── LOCAL DEV — MinIO (runs in Docker, emulates S3) ──────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=blood-bridge-nid-photos
AWS_ENDPOINT=http://minio:9000
# Your machine's LAN IP — must match API_BASE_URL in mobile/src/config.js
MINIO_PUBLIC_URL=http://YOUR_LAN_IP:9000

# ── PRODUCTION — choose one, replace the dev values above ────────────────────
#
# Option A: RunSite Object Storage (recommended if hosting on RunSite — free 5 GB)
#   runsite.app → Storage → Create bucket → Keys tab → Create Bucket Key (Read & Write)
#   Secret shown ONCE — copy immediately.
#
# AWS_ACCESS_KEY_ID=rs_ak_stg_xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=rs_sk_stg_xxxxxxxxxxxxxxxxxxxx
# AWS_REGION=auto
# AWS_S3_BUCKET=blood-bridge-nid-photos
# AWS_ENDPOINT=https://s3.runsite.app
#
# Option B: Cloudflare R2 (free 10 GB, no egress fees)
#   cloudflare.com → R2 → Create bucket → API Tokens → Create R2 API token
#
# AWS_ACCESS_KEY_ID=your_r2_access_key_id
# AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# AWS_REGION=auto
# AWS_S3_BUCKET=blood-bridge-nid-photos
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
#
# Option C: AWS S3
#   AWS Console → IAM → Create user → AmazonS3FullAccess → Generate access key
#
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=blood-bridge-nid-photos
