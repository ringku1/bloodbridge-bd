# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# This .env.example file is safe to commit (no real values).

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Leave blank in dev — all origins are allowed (Postman, Expo, curl all work).
# TODO (production): set to your real domains, e.g.:
# ALLOWED_ORIGINS=https://yourapp.com,https://admin.yourapp.com
ALLOWED_ORIGINS=

# ─── Database ─────────────────────────────────────────────────────────────────
# When running via docker-compose, host is "postgres" (service name).
# When running locally (npm run dev without Docker), host is "localhost".
DATABASE_URL=postgresql://user:password@localhost:5432/blooddonor

# ─── Redis ────────────────────────────────────────────────────────────────────
# Same note: "redis" inside Docker, "localhost" outside.
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d

# ─── OTP / SMS (SSL Wireless — Bangladesh) ────────────────────────────────────
# Set USE_MOCK_SMS=true during development.
# OTP will be printed to the server console instead of sending a real SMS.
# When you're ready for production, set USE_MOCK_SMS=false and fill the keys below.
USE_MOCK_SMS=true
SSL_WIRELESS_API_KEY=your_api_key_here
SSL_WIRELESS_SID=your_sid_here
SSL_WIRELESS_SENDER=BloodBridge

# ─── Firebase Cloud Messaging (push notifications) ────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
# Paste the full private key including -----BEGIN/END PRIVATE KEY----- lines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com

# ─── Twilio Proxy (masked phone calls) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PROXY_SERVICE_SID=your_proxy_service_sid

# ─── File Storage (NID photos) ───────────────────────────────────────────────
# Development: MinIO runs in Docker and emulates S3 locally.
#   View uploaded files at http://localhost:9001 (login: minioadmin / minioadmin)
#   Leave AWS_ENDPOINT set to point the SDK at MinIO instead of real AWS.
#
# Production: delete the AWS_ENDPOINT line and replace the keys with real AWS credentials.
#   AWS Console → IAM → Create User → AmazonS3FullAccess → Generate access key
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=blood-bridge-nid-photos
AWS_ENDPOINT=http://localhost:9000
# TODO (production): remove AWS_ENDPOINT above and set real AWS values:
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=blood-bridge-nid-photos

# ─── Admin ────────────────────────────────────────────────────────────────────
# A simple shared secret for admin-only endpoints (e.g. NID approval).
# Pass as header: x-admin-secret: <value>
ADMIN_SECRET=change_this_admin_secret_in_production
