# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# This .env.example file is safe to commit (no real values).
#
# For production: set these variables in Vercel dashboard (API) and Cloudflare Worker dashboard (cron)


# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Production: NODE_ENV=production
# Production: ALLOWED_ORIGINS=https://blood-bridge-admin-dev.vercel.app
ALLOWED_ORIGINS=


# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: "postgres" is the Docker service name.
# Production: copy connection string from Neon → your project → Connection Details → "Connection string"
DATABASE_URL=postgresql://user:password@postgres:5432/blooddonor


# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: "redis" is the Docker service name.
# Production: copy URL from Redis Cloud → your database → Configuration → "Public endpoint"
#   Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://redis:6379


# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d


# ─── Admin ────────────────────────────────────────────────────────────────────
# Must be 32+ characters in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change_this_admin_secret_in_production

# ─── Cron (Cloudflare Worker) ─────────────────────────────────────────────────
# Shared secret between the Cloudflare Worker and this API.
# The Worker sends this as x-cron-secret header; the API checks it on every cron route.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=change_this_cron_secret_in_production


# ─── SMS (caregiver escalation only — SSL Wireless) ──────────────────────────
# Used only for level-2 escalation to caregivers (not for user auth).
# USE_MOCK_SMS=true  → message printed to console. Use in dev.
# USE_MOCK_SMS=false → Real SMS. Fill keys below. Get from sslwireless.com
USE_MOCK_SMS=true
SSL_WIRELESS_API_KEY=your_api_key_here
SSL_WIRELESS_SID=your_sid_here
SSL_WIRELESS_SENDER=BloodBridge


# ─── Email (Gmail SMTP via Nodemailer) ────────────────────────────────────────
# Used for: email-verify OTP, change-email/password OTP, forgot-password.
# USE_MOCK_EMAIL=true  → email printed to console. Use in dev.
# USE_MOCK_EMAIL=false → real send via Gmail SMTP.
#   1. Turn on 2FA at https://myaccount.google.com/security
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
USE_MOCK_EMAIL=true
GMAIL_USER=
GMAIL_APP_PASSWORD=
FRONTEND_RESET_URL=https://blood-bridge-admin.vercel.app/reset


# ─── Push Notifications (Expo Push — no credentials needed) ──────────────────
# Expo Push is credential-free on the backend.
# Mobile app registers its token via PUT /api/donors/fcm-token.
# For production builds: cd mobile && npx eas init


# ─── File Storage (NID Photos) ───────────────────────────────────────────────

# ── LOCAL DEV — MinIO (runs in Docker, emulates S3) ──────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=blood-bridge-nid-photos
AWS_ENDPOINT=http://minio:9000
# Your machine's LAN IP — must match API_BASE_URL in mobile/src/config.js
MINIO_PUBLIC_URL=http://YOUR_LAN_IP:9000

# ── PRODUCTION — choose one, replace the dev values above ────────────────────
#
# Option A: Backblaze B2 (free 10 GB, no credit card required — recommended)
#   backblaze.com → B2 Cloud Storage → Buckets → Create bucket (Private)
#   App Keys → Add Application Key (Read & Write) → copy keyID + applicationKey
#   Endpoint shown on the bucket page (e.g. s3.us-west-004.backblazeb2.com)
#
# AWS_ACCESS_KEY_ID=your_backblaze_keyID
# AWS_SECRET_ACCESS_KEY=your_backblaze_applicationKey
# AWS_REGION=us-west-004
# AWS_S3_BUCKET=blood-bridge-nid-photos
# AWS_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#
# Option B: Cloudflare R2 (free 10 GB, no egress fees — requires credit card on file)
#   cloudflare.com → R2 → Create bucket → Manage R2 API tokens → Create token
#
# AWS_ACCESS_KEY_ID=your_r2_access_key_id
# AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# AWS_REGION=auto
# AWS_S3_BUCKET=blood-bridge-nid-photos
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
#
# Option C: AWS S3 (requires credit card)
#   AWS Console → IAM → Create user → AmazonS3FullAccess → Generate access key
#
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=blood-bridge-nid-photos
